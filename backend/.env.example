# Copy this file to .env and fill in your actual values
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
GEMINI_API_KEY=your_gemini_api_key_here

# Auth — choose ONE of the two options below:
# Option A (production/Render): set the RSA public key from Clerk dashboard
CLERK_PEM_PUBLIC_KEY=your_clerk_pem_public_key_here

# Option B (local dev, simpler): use Clerk's JWKS endpoint directly
# Find it at: https://dashboard.clerk.com → API Keys → Advanced → JWKS URL
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
